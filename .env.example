# ── Telegram ──────────────────────────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Channel username (with @) or numeric ID (no @)
TELEGRAM_CHANNEL=@your_channel_name

# ── GitHub ────────────────────────────────────────────────────────────────────
# Create a token at https://github.com/settings/tokens  (needs "repo" scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "owner/repository-name"
GITHUB_REPO=yourusername/v2ray-configs

# ── Bot behaviour (optional) ──────────────────────────────────────────────────
# How many messages to look back on each run (default 200)
FETCH_LIMIT=200

# Seconds between polling runs (default 3600 = 1 hour)
POLL_INTERVAL_SEC=3600
